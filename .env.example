# Database Configuration
DATABASE_URL=postgresql://ideaforge:ideaforge_dev_password@localhost:5432/ideaforge
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key-here
CLAUDE_API_KEY=your-claude-api-key-here

# Email Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ideaforge.dev

# File Storage Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ideaforge
MINIO_SECRET_KEY=ideaforge_minio_password
MINIO_BUCKET=ideaforge-files

# Application Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Deployment Configuration (for production)
CLOUD_PROVIDER=aws
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TERRAFORM_STATE_BUCKET=

# Monitoring
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=